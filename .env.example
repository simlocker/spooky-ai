# Prompt Security Config Variables (Prompt Security App ID is mandatory for the app to work)
# Remember to change your Gateway URL if needed

DEMO_USER_EMAIL=user@example.com
PS_APP_ID=your_prompt_security_app_id_here
PS_GATEWAY_URL=https://******.prompt.security

# LLM Keys (at least ONE required)
# Gemini and Groq use the direct API integration method.
# Cohere and OpenRouter use the AI Gateway (Reverse Proxy) method through Prompt Security.

# --- Direct API integrations ---
GEMINI_FREE_API_KEY=your_google_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# --- AI Gateway (Reverse Proxy) integrations ---
# OpenAI: key at https://platform.openai.com/api-keys — routed through PS Gateway
OPENAI_API_KEY=your_openai_key_here

# --- Direct API integrations (with PS API-level protection) ---
# Cohere: free trial key at https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_key_here

# OpenRouter: free account at https://openrouter.ai/keys  (use models ending in :free)
OPENROUTER_API_KEY=your_openrouter_key_here

# --- Optional Gemini model overrides ---
# DEFAULT_GEMINI_MODEL=gemini-2.0-flash
# FALLBACK_GEMINI_MODELS=gemini-1.5-pro,gemini-1.5-flash
# AUTO_SELECT_GEMINI_MODEL=true

